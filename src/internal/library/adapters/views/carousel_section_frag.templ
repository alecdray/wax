package views

import (
	"fmt"
	"github.com/alecdray/wax/src/internal/core/templates"
	"github.com/alecdray/wax/src/internal/library"
)

type CarouselView string

const (
	CarouselViewRecentlyPlayed CarouselView = "recently-played"
	CarouselViewUnrated        CarouselView = "unrated"
	CarouselViewRerateDue      CarouselView = "rerate-due"
)

type CarouselSectionProps struct {
	RegularAlbums []library.AlbumSummaryDTO
	RerateAlbums  []library.RerateAlbumDTO
	Active        CarouselView
}

templ carouselStrip(albums []library.AlbumSummaryDTO, emptyMsg string) {
	if len(albums) == 0 {
		<div data-testid="carousel-strip-empty" class="px-4 py-4 text-xs text-subtle">{ emptyMsg }</div>
	} else {
		<div data-testid="carousel-strip" class="carousel carousel-end gap-3 px-4 py-2 w-full overscroll-x-none">
			for _, album := range albums {
				<div class="carousel-item">
					if album.InLibrary {
						<a
							href={ templ.URL(fmt.Sprintf("/app/library/albums/%s", album.ID)) }
							class="flex flex-col items-center gap-1 hover-fade-out w-26"
							data-testid="carousel-strip-album-card"
						>
							@carouselCardInner(album)
						</a>
					} else {
						<button
							type="button"
							hx-get={ fmt.Sprintf("/app/library/discover/album-menu?spotifyId=%s", album.SpotifyID) }
							hx-swap="none"
							class="flex flex-col items-center gap-1 hover-fade-out w-26 cursor-pointer"
							data-testid="carousel-strip-discover-card"
						>
							@carouselCardInner(album)
						</button>
					}
				</div>
			}
		</div>
	}
}

templ carouselCardInner(album library.AlbumSummaryDTO) {
	if album.ImageURL != "" {
		<div class="avatar">
			<div class="mask mask-squircle h-24 w-24 flex-shrink-0">
				<img src={ album.ImageURL } alt={ album.Title }/>
			</div>
		</div>
	}
	<div class="flex items-center gap-1 w-full min-w-0">
		if !album.InLibrary {
			if album.OnRadar {
				<div class="tooltip tooltip-right shrink-0 text-xs text-subtle" data-tip="On radar">
					@templates.Icon(templates.IconProps{Name: "compass", Style: templates.IconStyleFill})
				</div>
			} else {
				<div class="tooltip tooltip-right shrink-0 text-xs text-subtle" data-tip="Not in library">
					@templates.Icon(templates.IconProps{Name: "compass"})
				</div>
			}
		}
		<span class="text-xs text-nowrap truncate text-left">{ album.Title }</span>
	</div>
	if album.Artists != "" {
		<span class="text-xs text-nowrap truncate w-full text-left text-subtle">{ album.Artists }</span>
	}
}

templ rerateCarouselStrip(albums []library.RerateAlbumDTO) {
	if len(albums) == 0 {
		<div data-testid="rerate-carousel-strip-empty" class="px-4 py-4 text-xs text-subtle">No albums due for rerate</div>
	} else {
		<div data-testid="rerate-carousel-strip" class="carousel carousel-end gap-3 px-4 py-2 w-full overscroll-x-none">
			for _, album := range albums {
				<div class="carousel-item">
					<a
						href={ templ.URL(fmt.Sprintf("/app/library/albums/%s", album.ID)) }
						class="flex flex-col items-center gap-1 hover-fade-out w-26"
					>
						if album.ImageURL != "" {
							<div class="avatar">
								<div class="mask mask-squircle h-24 w-24 flex-shrink-0">
									<img src={ album.ImageURL } alt={ album.Title }/>
								</div>
							</div>
						}
						<span class="text-xs text-nowrap truncate w-full text-left">{ album.Title }</span>
						if album.Artists != "" {
							<span class="text-xs text-nowrap truncate w-full text-left text-subtle">{ album.Artists }</span>
						}
					</a>
				</div>
			}
		</div>
	}
}

templ CarouselSectionFrag(props CarouselSectionProps) {
	<div
		id="carousel-section"
		data-testid="carousel-section"
		class="w-full flex-shrink-0"
		hx-get="/app/library/dashboard/carousel"
		hx-trigger="libraryUpdated from:body"
		hx-swap="outerHTML"
	>
		<div class="flex items-center gap-3 px-4 pb-1">
			<button
				class={ "text-xs font-semibold uppercase tracking-widest transition-colors", templ.KV("text-default", props.Active == CarouselViewRecentlyPlayed), templ.KV("text-subtle hover:text-muted cursor-pointer", props.Active != CarouselViewRecentlyPlayed) }
				if props.Active != CarouselViewRecentlyPlayed {
					hx-get="/app/library/dashboard/carousel?view=recently-played"
					hx-target="#carousel-section"
					hx-swap="outerHTML"
				}
				data-testid="carousel-section-recently-spun-tab"
			>Recently Spun</button>
			<span class="text-ghost cursor-default">|</span>
			<button
				class={ "text-xs font-semibold uppercase tracking-widest transition-colors", templ.KV("text-default", props.Active == CarouselViewUnrated), templ.KV("text-subtle hover:text-muted cursor-pointer", props.Active != CarouselViewUnrated) }
				if props.Active != CarouselViewUnrated {
					hx-get="/app/library/dashboard/carousel?view=unrated"
					hx-target="#carousel-section"
					hx-swap="outerHTML"
				}
				data-testid="carousel-section-unrated-tab"
			>Unrated</button>
			<span class="text-ghost cursor-default">|</span>
			<button
				class={ "text-xs font-semibold uppercase tracking-widest transition-colors", templ.KV("text-default", props.Active == CarouselViewRerateDue), templ.KV("text-subtle hover:text-muted cursor-pointer", props.Active != CarouselViewRerateDue) }
				if props.Active != CarouselViewRerateDue {
					hx-get="/app/library/dashboard/carousel?view=rerate-due"
					hx-target="#carousel-section"
					hx-swap="outerHTML"
				}
				data-testid="carousel-section-rerate-due-tab"
			>Rerate Due</button>
		</div>
		switch props.Active {
		case CarouselViewUnrated:
			@carouselStrip(props.RegularAlbums, "No unrated albums in your library")
		case CarouselViewRerateDue:
			@rerateCarouselStrip(props.RerateAlbums)
		default:
			@carouselStrip(props.RegularAlbums, "No recently played albums")
		}
	</div>
}
