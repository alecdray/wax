package templates

type PageLayoutProps struct {
  Title string
  // ActiveNav names the current top-level destination ("library" | "discover").
  // Leave empty for chrome-less pages (e.g. login) to suppress the bottom nav.
  ActiveNav string
}

templ PageLayoutComponent(props PageLayoutProps) {
  @RootComponent(RootProps{
    Title: props.Title,
  }) {
    { children... }
    if props.ActiveNav != "" {
      @BottomNav(props.ActiveNav)
    }
  }
}
