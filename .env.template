# Environment Configuration Template
# Copy this file to .env and fill in the values

# Application Environment
# Options: local, development, production
ENV=local

# Server Host
HOST=http://127.0.0.1

# Server Port
# The port the HTTP server will listen on
PORT=4691

# Database Configuration
# Path to the SQLite database file
# Prod suggestion: /var/lib/wax/wax.db
DB_PATH=./tmp/db.sql

# Goose Migration Configuration
# Driver for database migrations
GOOSE_DRIVER=sqlite3

# Database connection string for migrations
GOOSE_DBSTRING=./tmp/db.sql

# Directory containing migration files
GOOSE_MIGRATION_DIR=./db/migrations

# Spotify API Credentials
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_ID=your_spotify_client_id
SPOTIFY_SECRET=your_spotify_client_secret

# Discogs API Credentials
# Get these from https://www.discogs.com/settings/developers
DISCOGS_ID=your_discogs_consumer_key
DISCOGS_SECRET=your_discogs_consumer_secret

# Contact Email
# Used in User-Agent headers for API requests (MusicBrainz, etc.)
CONTACT_EMAIL="your_email@example.com"

# JWT Secret
# Generate with: openssl rand -hex 32
# Used for signing JWT authentication tokens
JWT_SECRET=your_jwt_secret_here

# Spotify Token Secret
# Generate with: openssl rand -hex 32
# Used for encrypting Spotify refresh tokens in the database
SPOTIFY_TOKEN_SECRET=your_spotify_token_secret_here

# E2E Testing
# User ID of a seeded local account used for authenticated E2E tests.
# Must exist in the local database and have a Spotify refresh token stored.
# Find it with: sqlite3 ./tmp/db.sql "SELECT id FROM users LIMIT 1;"
E2E_TEST_USER_ID=

# Album ID of an album in the test user's library (no listening history required).
# Find it with: sqlite3 ./tmp/db.sql "SELECT a.id FROM albums a JOIN releases r ON r.album_id = a.id JOIN user_releases ur ON ur.release_id = r.id LIMIT 1;"
E2E_TEST_ALBUM_ID=

# Album ID of an album in the test user's library that has listening history.
# Falls back to E2E_TEST_ALBUM_ID if not set.
# Find it with: sqlite3 ./tmp/db.sql "SELECT DISTINCT album_id FROM track_plays LIMIT 1;"
E2E_TEST_ALBUM_WITH_HISTORY_ID=
